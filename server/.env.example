# Server
PORT=5000
# Set to "production" when deploying. In production the server REFUSES to start
# unless JWT_SECRET, JWT_REFRESH_SECRET, MONGO_URI, and CLIENT_ORIGIN are set.
NODE_ENV=development

# Database — MongoDB Atlas connection string. REQUIRED in production.
# If unset, an in-memory MongoDB is used (dev/preview only, data resets on restart).
MONGO_URI=

# Auth — REQUIRED in production. Generate each with: openssl rand -base64 48
# Must be at least 32 characters and different from each other.
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# First admin account — created automatically at startup if it doesn't exist.
# Use this to get admin panel access on a fresh production database.
# ADMIN_PASSWORD must be at least 10 characters. Remove after first login if you wish.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Demo data — production never auto-seeds demo accounts. Set to "true" ONLY if
# you explicitly want the demo vendors/listings in your production database.
SEED_DEMO_DATA=

# CORS + email links — comma-separated list of allowed client origins.
# REQUIRED in production. The FIRST origin is also used to build links in
# emails (password reset, order notifications), so it MUST be your real
# deployed frontend URL — if this stays localhost, password reset emails
# will link to http://localhost:3000 and be useless for your users.
# e.g. https://pigeono.vercel.app or https://pigeono.com,https://www.pigeono.com
CLIENT_ORIGIN=http://localhost:3000

# Razorpay — vendor SUBSCRIPTION payments go to YOUR (platform owner's) Razorpay account.
# In development, a simulated payment mode is used when unset.
# In production, subscription checkout is DISABLED (503) until real keys are set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth — Web application client ID from Google Cloud Console.
# If unset, Google sign-in is hidden on the client.
# IMPORTANT: add your deployed frontend URL (e.g. https://your-app.vercel.app)
# to "Authorized JavaScript origins" in Google Cloud Console, or Google
# sign-in shows 403 "origin is not allowed for the given client ID".
GOOGLE_CLIENT_ID=

# SMTP (email OTP, notifications, receipts). REQUIRED in production —
# without it, registration/OTP/forgot-password endpoints return 503.
#
# WARNING: do NOT use Gmail (smtp.gmail.com) on Render/Vercel/other cloud
# hosts — Google blocks SMTP connections from data center IPs, causing
# "Connection timeout" errors. Use a transactional provider instead:
#   Brevo (recommended, free 300/day): https://app.brevo.com → SMTP & API
#     SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#     SMTP_USER=<your Brevo login>    SMTP_PASS=<your SMTP key>
#   Other options: Resend, Mailgun, Amazon SES.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Pigeono <no-reply@pigeono.com>"

# Cloudinary (optional — local uploads folder used otherwise)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
