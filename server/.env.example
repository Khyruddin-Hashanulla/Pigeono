# Server
PORT=5001
NODE_ENV=production

# Database — MongoDB Atlas
MONGO_URI=

# Auth — generate each with: openssl rand -base64 48 (min 32 chars)
JWT_SECRET=
JWT_REFRESH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Demo data — set to "true" to auto-seed demo vendors/listings
SEED_DEMO_DATA=false

# CORS — comma-separated client origins (e.g. https://pigeono.vercel.app)
CLIENT_ORIGIN=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
