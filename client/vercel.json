{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://pigeono-server-production.up.railway.app/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://pigeono-server-production.up.railway.app/uploads/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://pigeono-server-production.up.railway.app/socket.io/$1" },
    { "source": "/sitemap.xml", "destination": "https://pigeono-server-production.up.railway.app/sitemap.xml" },
    { "source": "/robots.txt", "destination": "https://pigeono-server-production.up.railway.app/robots.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
